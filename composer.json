{
    "name": "moaines/illumi-search",
    "description": "SQLite FTS5 full-text search for Laravel. BM25 ranking, search-as-you-type, multilingual (Latin, CJK, Arabic, Cyrillic), accent-insensitive, per-column weights, spellcheck, multi-tenant, authorization. Searchable trait with queue/sync/lazy batch indexing. No external services.",
    "version": "1.13.0",
    "type": "library",
    "keywords": ["laravel", "self-hosted", "fulltext-search", "search", "sqlite", "fts5", "string"],
    "license": "MIT",
    "authors": [
        {
            "name": "moaines",
            "homepage": "https://github.com/moaines"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-sqlite3": "*",
        "ext-mbstring": "*",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "symfony/string": "^7.0 || ^8.0",
        "wamania/php-stemmer": "^4.0"
    },
    "suggest": {
        "ext-intl": "Required for advanced Unicode normalization and CJK tokenization. Without it, a fallback processor using symfony/string is used."
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0",
        "filament/filament": "^3.0",
        "php-debugbar/php-debugbar": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Moaines\\IllumiSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moaines\\IllumiSearch\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse --memory-limit=2G",
        "format": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moaines\\IllumiSearch\\IllumiSearchServiceProvider"
            ],
            "aliases": {
                "IllumiSearch": "Moaines\\IllumiSearch\\Facades\\IllumiSearch"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
