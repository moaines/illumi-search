<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="vendor/autoload.php"
    colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
            <exclude>tests/Feature/Engines/AbstractEngineTest.php</exclude>
        </testsuite>
    </testsuites>

    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="ILLUMI_SEARCH_MYSQL_HOST" value="127.0.0.1"/>
        <env name="ILLUMI_SEARCH_MYSQL_PORT" value="3306"/>
        <env name="ILLUMI_SEARCH_MYSQL_DATABASE" value="illumi-search-test-db"/>
        <env name="ILLUMI_SEARCH_MYSQL_USERNAME" value="root"/>
        <env name="ILLUMI_SEARCH_MYSQL_PASSWORD" value="password"/>
    </php>

    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
